# ===========================================================================
# Line Cut — Environment variables (TEMPLATE)
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# git-ignored, so secrets never get committed. See docs/sticker-shop-setup.md
# for a step-by-step guide on obtaining each value.
#
# Naming rule: variables prefixed NEXT_PUBLIC_ are exposed to the browser
# (safe, non-secret). Everything else is SERVER-ONLY — never prefix a secret
# with NEXT_PUBLIC_.
# ===========================================================================

# --- Resend: transactional email (contact form + order notifications) ------
# Get an API key at https://resend.com (Dashboard -> API Keys).
RESEND_API_KEY=
# Inbox that receives website contact-form submissions.
CONTACT_EMAIL=info@example.com
# Verified "from" sender on your Resend-verified domain. Must be a domain you
# verified in Resend, e.g. "Line Cut <noreply@linecut.co.il>".
CONTACT_FROM=Line Cut <noreply@yourdomain.com>
# Inbox that receives NEW STICKER ORDER notifications. Can be the same as
# CONTACT_EMAIL.
OWNER_NOTIFY_EMAIL=orders@example.com

# --- Supabase: database + auth (NOT file storage — that's S3 below) --------
# Project URL, e.g. https://abcdefgh.supabase.co
# Dashboard -> Project Settings -> Data API -> Project URL.
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe in the browser; gated by Row-Level Security).
# Dashboard -> Project Settings -> API Keys -> anon / public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY service-role key (bypasses RLS — treat like a root password).
# Dashboard -> Project Settings -> API Keys -> service_role. NEVER expose to
# the browser; only used in server-only modules.
SUPABASE_SERVICE_ROLE_KEY=

# --- AWS S3: sticker file storage ------------------------------------------
# Two private buckets in the SAME region, both reached with the one IAM user
# below (the IAM policy is scoped to both — see docs/sticker-shop-setup.md §3).
# Region the buckets live in, e.g. eu-central-1 (Frankfurt) or il-central-1.
AWS_REGION=
# Orders bucket — every order (drafts + confirmed). The browser uploads here
# (this is the only bucket that needs CORS).
S3_STICKERS_BUCKET=
# Paid bucket — on payment the order folder is copied here + the receipt is
# written into it. Server-side access only (no CORS needed).
S3_STICKERS_PAID_BUCKET=
# SERVER-ONLY IAM credentials for an IAM user scoped to BOTH buckets above.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Misc ------------------------------------------------------------------
# Lifetime (seconds) of the signed download links emailed to the owner.
# 604800 = 7 days. Safe to leave as-is.
ORDER_FILES_LINK_TTL=604800
